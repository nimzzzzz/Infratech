# ─────────────────────────────────────────────────────────────────────────────
# AllInfratech — Environment variables (TEMPLATE)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev.
# Add the same vars to Vercel project settings for staging/production.
# Never commit .env.local. .env.example is safe to commit.
#
# Stages refer to the rollout plan — vars not needed until Stage N can stay
# blank until then, but the app must boot with them missing in dev.
# ─────────────────────────────────────────────────────────────────────────────


# ── App ──────────────────────────────────────────────────────────────────────
# Public URL of the deployed site. Used for OG tags, sitemap, email links,
# Clerk redirect URLs, OAuth callbacks. No trailing slash.
# Local: http://localhost:3000  /  Prod: https://allinfratech.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Node environment. Next.js sets this automatically in most cases — only set
# explicitly if you need to override (e.g. running prod build locally).
# NODE_ENV=development


# ── Database — Neon Postgres ─────────────────────────────────────────────────
# Stage 1.
# Two URLs from the same Neon project:
#   • DATABASE_URL → pooled connection (with -pooler in hostname). Used by
#     the running app (server components, API routes). Required.
#   • DATABASE_URL_UNPOOLED → direct connection. Used by Drizzle migrations
#     and the seed script. Required for db:migrate and db:seed.
# Get both from Neon dashboard → Connection Details → toggle "Pooled connection".
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require


# ── Auth — Clerk (single instance, role-based) ───────────────────────────────
# Stage 1.
# One Clerk application. Audience separation is by `publicMetadata.role`:
#   • role = "vendor" → LinkedIn OAuth, lands on /dashboard
#   • role = "admin"  → email+password + 2FA enforced, lands on /admin
# Both sign-in methods are enabled in the same Clerk app; middleware checks
# role + 2FA on /admin/**.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Webhook signing secret. Set up in Clerk dashboard → Webhooks pointing to:
#   {NEXT_PUBLIC_SITE_URL}/api/webhooks/clerk
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me

# --- Clerk redirect paths ---
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/onboarding


# ── Email — Resend ───────────────────────────────────────────────────────────
# Stage 3 (contact-vendor pipeline) onwards.
# Verify the sending domain in Resend before any email will deliver.
RESEND_API_KEY=re_replace_me

# Address that transactional emails are sent FROM.
# Must be on a domain you've verified in Resend.
# Production: directory@allinfratech.com  (lib/email/from.ts wraps as
# "AllInfratech Directory <…>")
EMAIL_FROM=onboarding@resend.dev

# Inbox where contact-vendor inquiries are BCC'd and admin notifications go.
# Internal — typically the team's shared mailbox.
EMAIL_CONTACT_INBOX=replace-me@example.com

# Optional: Reply-To address shown to recipients of transactional mail.
# If unset, replies go to EMAIL_FROM.
# EMAIL_REPLY_TO=team@example.com


# ── File storage — Vercel Blob ───────────────────────────────────────────────
# Stage 4 (vendor logos + screenshots).
# Storage choice locked in Phase D.4 (2026-05-09): Vercel Blob over Cloudflare
# R2 to avoid R2's card-on-file requirement. Stage 4 Phase C uses the
# `@vercel/blob` SDK, NOT `@aws-sdk/client-s3`.
# Get this token from: Vercel project → Storage → Blob → store
# "allinfratech-uploads" → .env.local tab.
# Auto-set on Vercel for Production + Preview + Development scopes.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me


# ── Error monitoring — Sentry ────────────────────────────────────────────────
# Stage 1 (set up early so errors during dev are captured).
# Get DSN from Sentry → Project Settings → Client Keys.
NEXT_PUBLIC_SENTRY_DSN=https://replace_me@oXXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN=https://replace_me@oXXXXXXX.ingest.sentry.io/XXXXXXX

# Used during build to upload source maps. Generate a Sentry auth token
# scoped to "project:releases".
SENTRY_AUTH_TOKEN=sntrys_replace_me
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=allinfratech


# ── Analytics — Plausible ────────────────────────────────────────────────────
# Stage 7. Privacy-friendly, cookie-free analytics.
# Domain is the one you registered in Plausible (no scheme, no path).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=allinfratech.com

# Optional: self-hosted Plausible URL. Leave unset if using plausible.io cloud.
# NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.allinfratech.com


# ── Webhooks / shared secrets ────────────────────────────────────────────────
# Stage 4+. A shared secret used by internal cron jobs or admin actions
# that don't go through user auth (e.g. nightly digest emails).
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# Stage 5. Optional: secret for cron jobs triggered by Vercel Cron.
# Vercel Cron sends this in the Authorization header.
CRON_SECRET=


# ── Feature flags / dev toggles ──────────────────────────────────────────────
# Stage 1. When true, /login, /dashboard, /admin show "demo mode" toggles
# (?as=new, ?as=returning) and seed data is loaded. MUST be false in prod.
# Auto-disabled when NODE_ENV=production regardless.
NEXT_PUBLIC_DEMO_MODE=false

# Stage 2. When true, the search input uses pg_trgm fuzzy match instead
# of strict tsvector match. Useful while content is sparse.
SEARCH_FUZZY=false


# ── Optional: third-party integrations (later stages) ────────────────────────
# Stage 7+. Newsletter capture (if used). Pick one provider.
# RESEND_AUDIENCE_ID=

# Stage 7+. If you add a CMS for editorial copy later. Currently admin panel
# handles all editable content, so this is unset.
# SANITY_PROJECT_ID=
# SANITY_DATASET=
